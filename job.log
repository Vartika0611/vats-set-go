  if content[i] == \'{\':\n            brace_count += 1\n        elif content[i] == \'}\':\n            if brace_count == 0:\n                end_body = i\n                break\n            brace_count -= 1\n        i += 1\n    \n    # New method body with ThreadPoolExecutor\n    new_body = \'\'\'\n        int pageSize = 100;\n        int threadCount = Math.min(Runtime.getRuntime().availableProcessors() * 2, 10);\n        ExecutorService executor = new ThreadPoolExecutor(\n                threadCount, threadCount, 0L, TimeUnit.MILLISECONDS,\n                new LinkedBlockingQueue<>());\n        \n        AtomicInteger errorCount = new AtomicInteger(0);\n        \n        // Migrate beta configs\n        int rowCount = configInfoBetaPersistService.configInfoBetaCount();\n        int pageCount = (int) Math.ceil(rowCount * 1.0 / pageSize);\n        for (int pageNo = 1; pageNo <= pageCount; pageNo++) {\n            final int currentPage = pageNo;\n            executor.submit(() -> {\n                try {\n                    Page<ConfigInfoBetaWrapper> page = configInfoBetaPersistService.findAllConfigInfoBetaForDumpAll(\n                            currentPage, pageSize);\n                    if (page != null) {\n                        for (ConfigInfoBetaWrapper cf : page.getPageItems()) {\n                            try {\n                                PropertyUtil.setGrayMigrateFlag(true);\n                                ConfigInfoGrayWrapper configInfo4Gray = configInfoGrayPersistService.findConfigInfo4Gray(\n                                        cf.getDataId(), cf.getGroup(), cf.getTenant(), BetaGrayRule.TYPE_BETA);\n                                if (configInfo4Gray == null || configInfo4Gray.getLastModified() < cf.getLastModified()) {\n                                    DEFAULT_LOG.info("[migrate beta to gray] dataId={}, group={}, tenant={},  md5={}",\n                                            cf.getDataId(), cf.getGroup(), cf.getTenant(), cf.getMd5());\n                                    ConfigGrayPersistInfo localConfigGrayPersistInfo = new ConfigGrayPersistInfo(\n                                            BetaGrayRule.TYPE_BETA, BetaGrayRule.VERSION, cf.getBetaIps(), BetaGrayRule.PRIORITY);\n                                    configInfoGrayPersistService.insertOrUpdateGray(cf, BetaGrayRule.TYPE_BETA,\n                                            GrayRuleManager.serializeConfigGrayPersistInfo(localConfigGrayPersistInfo),\n                                            NetUtils.localIP(), "nacos_auto_migrate");\n                                }\n                            } finally {\n                                PropertyUtil.clearGrayMigrateFlag();\n                            }\n                        }\n                    }\n                } catch (Exception e) {\n                    DEFAULT_LOG.error("[migrate-error] migrate beta page {} failed", currentPage, e);\n                    errorCount.incrementAndGet();\n                }\n            });\n        }\n        \n        // Wait for beta migration to complete\n        executor.shutdown();\n        if (!executor.awaitTermination(30, TimeUnit.MINUTES)) {\n            DEFAULT_LOG.error("[migrate-error] beta migration timeout");\n            executor.shutdownNow();\n        }\n        \n        if (errorCount.get() > 0) {\n            throw new Exception("Beta migration completed with " + errorCount.get() + " errors");\n        }\n        \n        // Migrate tag configs\n        executor = new ThreadPoolExecutor(\n                threadCount, threadCount, 0L, TimeUnit.MILLISECONDS,\n                new LinkedBlockingQueue<>());\n        errorCount.set(0);\n        \n        rowCount = configInfoTagPersistService.configInfoTagCount();\n        pageCount = (int) Math.ceil(rowCount * 1.0 / pageSize);\n        for (int pageNo = 1; pageNo <= pageCount; pageNo++) {\n            final int currentPage = pageNo;\n            executor.submit(() -> {\n                try {\n                    Page<ConfigInfoTagWrapper> page = configInfoTagPersistService.findAllConfigInfoTagForDumpAll(\n                            currentPage, pageSize);\n                    if (page != null) {\n                        for (ConfigInfoTagWrapper cf : page.getPageItems()) {\n                            try {\n                                PropertyUtil.setGrayMigrateFlag(true);\n                                ConfigInfoGrayWrapper configInfo4Gray = configInfoGrayPersistService.findConfigInfo4Gray(\n                                        cf.getDataId(), cf.getGroup(), cf.getTenant(), TagGrayRule.TYPE_TAG + "_" + cf.getTag());\n                                if (configInfo4Gray == null || configInfo4Gray.getLastModified() < cf.getLastModified()) {\n                                    DEFAULT_LOG.info("[migrate tag to gray] dataId={}, group={}, tenant={},  md5={}",\n                                            cf.getDataId(), cf.getGroup(), cf.getTenant(), cf.getMd5());\n                                    ConfigGrayPersistInfo localConfigGrayPersistInfo = new ConfigGrayPersistInfo(\n                                            TagGrayRule.TYPE_TAG, TagGrayRule.VERSION, cf.getTag(), TagGrayRule.PRIORITY);\n                                    configInfoGrayPersistService.insertOrUpdateGray(cf, TagGrayRule.TYPE_TAG + "_" + cf.getTag(),\n                                            GrayRuleManager.serializeConfigGrayPersistInfo(localConfigGrayPersistInfo),\n                                            NetUtils.localIP(), "nacos_auto_migrate");\n                                }\n                            } finally {\n                                PropertyUtil.clearGrayMigrateFlag();\n                            }\n                        }\n                    }\n                } catch (Exception e) {\n                    DEFAULT_LOG.error("[migrate-error] migrate tag page {} failed", currentPage, e);\n                    errorCount.incrementAndGet();\n                }\n            });\n        }\n        \n        // Wait for tag migration to complete\n        executor.shutdown();\n        if (!executor.awaitTermination(30, TimeUnit.MINUTES)) {\n            DEFAULT_LOG.error("[migrate-error] tag migration timeout");\n            executor.shutdownNow();\n        }\n        \n        if (errorCount.get() > 0) {\n            throw new Exception("Tag migration completed with " + errorCount.get() + " errors");\n        }\n    \'\'\'\n    \n    content = content[:start_body] + new_body + content[end_body:]\n\nwith open(\'./config/src/main/java/com/alibaba/nacos/config/server/service/ConfigGrayModelMigrateService.java\', \'w\') as f:\n    f.write(content)\n\nprint("Patched ConfigGrayModelMigrateService.java")\nPYEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
